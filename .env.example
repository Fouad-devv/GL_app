# Copy this file to .env and fill in real values — never commit .env

POSTGRES_DB=postgres
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password

KEYCLOAK_ADMIN=your_kc_admin
KEYCLOAK_ADMIN_PASSWORD=your_kc_admin_password

DB_URL=jdbc:postgresql://postgres:5432/postgres
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

KEYCLOAK_SERVER_URL=http://keycloak:8080
KEYCLOAK_REALM=GL_Project
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/GL_Project
KEYCLOAK_JWK_URI=http://keycloak:8080/realms/GL_Project/protocol/openid-connect/certs
KEYCLOAK_ADMIN_USERNAME=your_kc_admin
KEYCLOAK_ADMIN_PASSWORD=your_kc_admin_password

# Frontend build args (baked into the React bundle at docker build time)
# VITE_KEYCLOAK_URL must be the browser-accessible Keycloak address (host:8081)
VITE_KEYCLOAK_URL=http://your_host:8081
VITE_KEYCLOAK_CLIENT_ID=FrontJL
