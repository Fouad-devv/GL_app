# Copy this file to application.properties and fill in your values

spring.application.name=MaintenanceApp
server.port=5000
server.servlet.context-path=/api

spring.datasource.url=jdbc:postgresql://localhost:5432/postgres
spring.datasource.username=YOUR_DB_USER
spring.datasource.password=YOUR_DB_PASSWORD
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false

spring.security.oauth2.resourceserver.jwt.issuer-uri=http://localhost:8081/realms/JL_Project
spring.security.oauth2.resourceserver.jwt.jwk-set-uri=http://localhost:8081/realms/JL_Project/protocol/openid-connect/certs

keycloak.server-url=http://localhost:8081
keycloak.realm=JL_Project
keycloak.admin-client-id=admin-cli
keycloak.admin-username=YOUR_KEYCLOAK_ADMIN
keycloak.admin-password=YOUR_KEYCLOAK_PASSWORD

management.endpoints.web.exposure.include=health,info,metrics
management.endpoint.health.show-details=always
server.servlet.session.timeout=30m
spring.mvc.async.request-timeout=30000
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB
